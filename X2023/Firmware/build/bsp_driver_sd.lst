  47:FATFS/Target/bsp_driver_sd.c ****  static HAL_StatusTypeDef SD_DMAConfigRx(SD_HandleTypeDef *hsd)
  48:FATFS/Target/bsp_driver_sd.c ****   {
  49:FATFS/Target/bsp_driver_sd.c ****     static DMA_HandleTypeDef hdma_rx;
  50:FATFS/Target/bsp_driver_sd.c ****     HAL_StatusTypeDef status = HAL_ERROR;
  51:FATFS/Target/bsp_driver_sd.c ****   
  52:FATFS/Target/bsp_driver_sd.c ****     /* Configure DMA Rx parameters */
  53:FATFS/Target/bsp_driver_sd.c ****     hdma_rx.Init.Request             = DMA_REQUEST_7;
  54:FATFS/Target/bsp_driver_sd.c ****     hdma_rx.Init.Direction           = DMA_PERIPH_TO_MEMORY;
  55:FATFS/Target/bsp_driver_sd.c ****     hdma_rx.Init.PeriphInc           = DMA_PINC_DISABLE;
  56:FATFS/Target/bsp_driver_sd.c ****     hdma_rx.Init.MemInc              = DMA_MINC_ENABLE;
  57:FATFS/Target/bsp_driver_sd.c ****     hdma_rx.Init.PeriphDataAlignment = DMA_PDATAALIGN_WORD;
  58:FATFS/Target/bsp_driver_sd.c ****     hdma_rx.Init.MemDataAlignment    = DMA_MDATAALIGN_WORD;
  59:FATFS/Target/bsp_driver_sd.c ****     hdma_rx.Init.Priority            = DMA_PRIORITY_VERY_HIGH;
  60:FATFS/Target/bsp_driver_sd.c ****   
  61:FATFS/Target/bsp_driver_sd.c ****     hdma_rx.Instance = DMA2_Channel4;
  62:FATFS/Target/bsp_driver_sd.c ****   
  63:FATFS/Target/bsp_driver_sd.c ****     /* Associate the DMA handle */
  64:FATFS/Target/bsp_driver_sd.c ****     __HAL_LINKDMA(hsd, hdmarx, hdma_rx);
  65:FATFS/Target/bsp_driver_sd.c ****   
  66:FATFS/Target/bsp_driver_sd.c ****     /* Stop any ongoing transfer and reset the state*/
  67:FATFS/Target/bsp_driver_sd.c ****     HAL_DMA_Abort(&hdma_rx);
  68:FATFS/Target/bsp_driver_sd.c ****   
  69:FATFS/Target/bsp_driver_sd.c ****     /* Deinitialize the Channel for new transfer */
  70:FATFS/Target/bsp_driver_sd.c ****     HAL_DMA_DeInit(&hdma_rx);
  71:FATFS/Target/bsp_driver_sd.c ****   
  72:FATFS/Target/bsp_driver_sd.c ****     /* Configure the DMA Channel */
  73:FATFS/Target/bsp_driver_sd.c ****     status = HAL_DMA_Init(&hdma_rx);
  74:FATFS/Target/bsp_driver_sd.c ****   
  75:FATFS/Target/bsp_driver_sd.c ****     /* NVIC configuration for DMA transfer complete interrupt */
  76:FATFS/Target/bsp_driver_sd.c ****     HAL_NVIC_SetPriority(DMA2_Channel4_IRQn, 6, 0);
  77:FATFS/Target/bsp_driver_sd.c ****     HAL_NVIC_EnableIRQ(DMA2_Channel4_IRQn);
  78:FATFS/Target/bsp_driver_sd.c ****   
