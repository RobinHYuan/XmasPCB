 173:ssd1306/ssd1306.c **** 
 174:ssd1306/ssd1306.c **** /* Fill the whole screen with the given color */
 175:ssd1306/ssd1306.c **** void ssd1306_Fill(SSD1306_COLOR color) {
 176:ssd1306/ssd1306.c ****     uint32_t i;
 177:ssd1306/ssd1306.c **** 
 178:ssd1306/ssd1306.c ****     for(i = 0; i < sizeof(SSD1306_Buffer); i++) {
 179:ssd1306/ssd1306.c ****         SSD1306_Buffer[i] = (color == Black) ? 0x00 : 0xFF;
 180:ssd1306/ssd1306.c ****     }
 181:ssd1306/ssd1306.c **** }
 182:ssd1306/ssd1306.c **** 
 183:ssd1306/ssd1306.c **** /* Write the screenbuffer with changed to the screen */
 184:ssd1306/ssd1306.c **** void ssd1306_UpdateScreen(void) {
 185:ssd1306/ssd1306.c ****     // Write data to each page of RAM. Number of pages
 186:ssd1306/ssd1306.c ****     // depends on the screen height:
 187:ssd1306/ssd1306.c ****     //
 188:ssd1306/ssd1306.c ****     //  * 32px   ==  4 pages
 189:ssd1306/ssd1306.c ****     //  * 64px   ==  8 pages
 190:ssd1306/ssd1306.c ****     //  * 128px  ==  16 pages
 191:ssd1306/ssd1306.c ****     for(uint8_t i = 0; i < SSD1306_HEIGHT/8; i++) {
 192:ssd1306/ssd1306.c ****         ssd1306_WriteCommand(0xB0 + i); // Set the current RAM page address.
 193:ssd1306/ssd1306.c ****         ssd1306_WriteCommand(0x00 + SSD1306_X_OFFSET_LOWER);
 194:ssd1306/ssd1306.c ****         ssd1306_WriteCommand(0x10 + SSD1306_X_OFFSET_UPPER);
 195:ssd1306/ssd1306.c ****         ssd1306_WriteData(&SSD1306_Buffer[SSD1306_WIDTH*i],SSD1306_WIDTH);
 196:ssd1306/ssd1306.c ****     }
 197:ssd1306/ssd1306.c **** }
