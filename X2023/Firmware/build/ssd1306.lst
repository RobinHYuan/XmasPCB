 198:ssd1306/ssd1306.c **** 
 199:ssd1306/ssd1306.c **** /*
 200:ssd1306/ssd1306.c ****  * Draw one pixel in the screenbuffer
 201:ssd1306/ssd1306.c ****  * X => X Coordinate
 202:ssd1306/ssd1306.c ****  * Y => Y Coordinate
 203:ssd1306/ssd1306.c ****  * color => Pixel color
 204:ssd1306/ssd1306.c ****  */
 205:ssd1306/ssd1306.c **** void ssd1306_DrawPixel(uint8_t x, uint8_t y, SSD1306_COLOR color) {
 206:ssd1306/ssd1306.c ****     if(x >= SSD1306_WIDTH || y >= SSD1306_HEIGHT) {
 207:ssd1306/ssd1306.c ****         // Don't write outside the buffer
 208:ssd1306/ssd1306.c ****         return;
 209:ssd1306/ssd1306.c ****     }
 210:ssd1306/ssd1306.c ****    
 211:ssd1306/ssd1306.c ****     // Draw in the right color
 212:ssd1306/ssd1306.c ****     if(color == White) {
 213:ssd1306/ssd1306.c ****         SSD1306_Buffer[x + (y / 8) * SSD1306_WIDTH] |= 1 << (y % 8);
 214:ssd1306/ssd1306.c ****     } else { 
 215:ssd1306/ssd1306.c ****         SSD1306_Buffer[x + (y / 8) * SSD1306_WIDTH] &= ~(1 << (y % 8));
 216:ssd1306/ssd1306.c ****     }
 217:ssd1306/ssd1306.c **** }
 218:ssd1306/ssd1306.c **** 
 219:ssd1306/ssd1306.c **** /*
 220:ssd1306/ssd1306.c ****  * Draw 1 char to the screen buffer
 221:ssd1306/ssd1306.c ****  * ch       => char om weg te schrijven
 222:ssd1306/ssd1306.c ****  * Font     => Font waarmee we gaan schrijven
 223:ssd1306/ssd1306.c ****  * color    => Black or White
 224:ssd1306/ssd1306.c ****  */
 225:ssd1306/ssd1306.c **** char ssd1306_WriteChar(char ch, FontDef Font, SSD1306_COLOR color) {
 226:ssd1306/ssd1306.c ****     uint32_t i, b, j;
 227:ssd1306/ssd1306.c ****     
 228:ssd1306/ssd1306.c ****     // Check if character is valid
 229:ssd1306/ssd1306.c ****     if (ch < 32 || ch > 126)
 230:ssd1306/ssd1306.c ****         return 0;
 231:ssd1306/ssd1306.c ****     
 232:ssd1306/ssd1306.c ****     // Check remaining space on current line
 233:ssd1306/ssd1306.c ****     if (SSD1306_WIDTH < (SSD1306.CurrentX + Font.FontWidth) ||
 234:ssd1306/ssd1306.c ****         SSD1306_HEIGHT < (SSD1306.CurrentY + Font.FontHeight))
 235:ssd1306/ssd1306.c ****     {
 236:ssd1306/ssd1306.c ****         // Not enough space on current line
 237:ssd1306/ssd1306.c ****         return 0;
 238:ssd1306/ssd1306.c ****     }
 239:ssd1306/ssd1306.c ****     
 240:ssd1306/ssd1306.c ****     // Use the font to write
 241:ssd1306/ssd1306.c ****     for(i = 0; i < Font.FontHeight; i++) {
 242:ssd1306/ssd1306.c ****         b = Font.data[(ch - 32) * Font.FontHeight + i];
 243:ssd1306/ssd1306.c ****         for(j = 0; j < Font.FontWidth; j++) {
 244:ssd1306/ssd1306.c ****             if((b << j) & 0x8000)  {
 245:ssd1306/ssd1306.c ****                 ssd1306_DrawPixel(SSD1306.CurrentX + j, (SSD1306.CurrentY + i), (SSD1306_COLOR) col
 246:ssd1306/ssd1306.c ****             } else {
 247:ssd1306/ssd1306.c ****                 ssd1306_DrawPixel(SSD1306.CurrentX + j, (SSD1306.CurrentY + i), (SSD1306_COLOR)!col
 248:ssd1306/ssd1306.c ****             }
 249:ssd1306/ssd1306.c ****         }
 250:ssd1306/ssd1306.c ****     }
 251:ssd1306/ssd1306.c ****     
 252:ssd1306/ssd1306.c ****     // The current space is now taken
 253:ssd1306/ssd1306.c ****     SSD1306.CurrentX += Font.FontWidth;
 254:ssd1306/ssd1306.c ****     
ARM GAS  /tmp/ccbB2Lxw.s 			page 6


 255:ssd1306/ssd1306.c ****     // Return written char for validation
 256:ssd1306/ssd1306.c ****     return ch;
 257:ssd1306/ssd1306.c **** }
 258:ssd1306/ssd1306.c **** 
 259:ssd1306/ssd1306.c **** /* Write full string to screenbuffer */
 260:ssd1306/ssd1306.c **** char ssd1306_WriteString(char* str, FontDef Font, SSD1306_COLOR color) {
 261:ssd1306/ssd1306.c ****     while (*str) {
 262:ssd1306/ssd1306.c ****         if (ssd1306_WriteChar(*str, Font, color) != *str) {
 263:ssd1306/ssd1306.c ****             // Char could not be written
 264:ssd1306/ssd1306.c ****             return *str;
 265:ssd1306/ssd1306.c ****         }
 266:ssd1306/ssd1306.c ****         str++;
 267:ssd1306/ssd1306.c ****     }
 268:ssd1306/ssd1306.c ****     
 269:ssd1306/ssd1306.c ****     // Everything ok
 270:ssd1306/ssd1306.c ****     return *str;
 271:ssd1306/ssd1306.c **** }
 272:ssd1306/ssd1306.c **** 
 273:ssd1306/ssd1306.c **** /* Position the cursor */
 274:ssd1306/ssd1306.c **** void ssd1306_SetCursor(uint8_t x, uint8_t y) {
 275:ssd1306/ssd1306.c ****     SSD1306.CurrentX = x;
 276:ssd1306/ssd1306.c ****     SSD1306.CurrentY = y;
 277:ssd1306/ssd1306.c **** }
 278:ssd1306/ssd1306.c **** 
 279:ssd1306/ssd1306.c **** /* Draw line by Bresenhem's algorithm */
 280:ssd1306/ssd1306.c **** void ssd1306_Line(uint8_t x1, uint8_t y1, uint8_t x2, uint8_t y2, SSD1306_COLOR color) {
 281:ssd1306/ssd1306.c ****     int32_t deltaX = abs(x2 - x1);
 282:ssd1306/ssd1306.c ****     int32_t deltaY = abs(y2 - y1);
 283:ssd1306/ssd1306.c ****     int32_t signX = ((x1 < x2) ? 1 : -1);
 284:ssd1306/ssd1306.c ****     int32_t signY = ((y1 < y2) ? 1 : -1);
 285:ssd1306/ssd1306.c ****     int32_t error = deltaX - deltaY;
